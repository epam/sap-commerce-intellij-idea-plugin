<idea-plugin>

    <extensions defaultExtensionNs="sap.commerce.toolset">
        <ui.toolWindowProvider implementation="sap.commerce.toolset.properties.ui.CxPropertiesToolWindowContentProvider"/>
    </extensions>

    <actions>
        <action id="sap.cx.properties.applyTemplate" class="sap.commerce.toolset.properties.actionSystem.CxApplyPropertyTemplateAction"/>
        <action id="sap.cx.properties.remote.fetch" class="sap.commerce.toolset.properties.actionSystem.CxFetchRemotePropertyStateAction"/>
        <action id="sap.cx.properties.custom.createTemplate" class="sap.commerce.toolset.properties.actionSystem.CxCreateCustomPropertyTemplateAction"/>
        <action id="sap.cx.properties.custom.addTemplate" class="sap.commerce.toolset.properties.actionSystem.CxAddCustomPropertyTemplateAction"/>
        <action id="sap.cx.properties.custom.deleteTemplate" class="sap.commerce.toolset.properties.actionSystem.CxDeleteCustomPropertyTemplateAction"/>
        <action id="sap.cx.properties.custom.editTemplate" class="sap.commerce.toolset.properties.actionSystem.CxEditCustomPropertyTemplateAction"/>

        <group id="sap.cx.properties.toolbar.actions" searchable="false">
            <reference ref="sap.commerce.toolset.hac.chooseConnection"/>
            <reference ref="sap.cx.properties.remote.fetch"/>
        </group>

        <group id="sap.cx.properties.template.item.actions" searchable="false">
            <reference ref="sap.cx.properties.applyTemplate"/>
            <reference ref="sap.cx.properties.custom.createTemplate"/>
            <reference ref="sap.cx.properties.custom.editTemplate"/>
            <reference ref="sap.cx.properties.custom.deleteTemplate"/>
        </group>

        <group id="sap.cx.properties.toolwindow.menu" popup="true" searchable="false" class="sap.commerce.toolset.properties.actionSystem.CxPropertyTemplateContextMenuActionGroup"/>
    </actions>
</idea-plugin>
