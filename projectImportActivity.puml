@startuml ProjectImportActivity
!theme plain

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ArrowColor #2C3E50
skinparam ActivityDiamondBackgroundColor #ECF0F1
skinparam ActivityDiamondBorderColor #95A5A6

' Color palette
!define ACCENT #E74C3C
!define PRIMARY #3498DB
!define SUCCESS #2ECC71
!define WARNING #F39C12
!define SECONDARY #9B59B6

skinparam ActivityBackgroundColor<<projectLevel>> PRIMARY
skinparam ActivityBackgroundColor<<moduleLevel>> ACCENT
skinparam ActivityBackgroundColor<<storageLevel>> SUCCESS
skinparam ActivityBackgroundColor<<postImport>> WARNING

skinparam NoteBorderColor #95A5A6
skinparam NoteBackgroundColor #FDFEFE

start
:ProjectImportTask.execute();
:Modal Progress with 95% Import, 5% Save; <<continuous>>

partition "**Import Project (95%)**" #E8F6F3 {
  :Get ProjectImportConfigurator\nExtension List;

  fork
    :ApplicationSettingsConfigurator;
    :Saves import settings to
    ApplicationSettings instance; <<continuous>>
  fork again
    :ProjectSettingsConfigurator;
    :Workspace/project settings,
    directory locations; <<continuous>>
  fork again
    :ProjectEncodingConfigurator;
  fork again
    :ProjectIconConfigurator;
  fork again
    :ProjectDictionaryConfigurator;
    :Adds module names to
    project dictionary; <<continuous>>
  fork again
    :ProjectLibrariesConfigurator;
  fork again
    :ProjectModulesDirectoryConfigurator;
  fork again
    :Only during Refresh; <<continuous>>
    :ResetCacheProjectBeforeRefreshConfigurator;
  fork again
    :Only during Refresh; <<continuous>>
    :SaveDocumentsProjectBeforeRefreshConfigurator;
  fork again
    partition "**ModulesConfigurator**" #D6EAF8 {
      :Create Module Entities\nfor chosen modules <<projectLevel>>;
      :Uses ModuleProvider.EP\nto create module entities; <<continuous>>

      :For each Module:\nConfigure Module;

      partition "**Module Configuration**" #EBF5FB {
        :Get ModuleImportConfigurator Extension List (filtered by type);

        fork
          :JavaModuleReadonlyConfigurator;
          :Sets readonly based on\nmodule type (OOTB/PLATFORM/EXT); <<continuous>>
        fork again
          partition "**Module Libraries**" #FADBD8 {
            :Get ModuleLibraryConfigurator.EP;
            fork
              :ConfigModuleLibraryConfigurator;
              :Links platform\nlicense library; <<continuous>>
            fork again
              :PlatformModuleLibraryConfigurator;
              :Links database\ndrivers library; <<continuous>>
            fork again
              :[Other ModuleLibraryConfigurator];
            end fork
          }
        fork again
          partition "**Content Root Entries**" #FADBD8 {
            fork
              :SourcesContentRootEntryConfigurator;
              :Configures src/\nand gensrc/; <<continuous>>
            fork again
              :TestSourcesContentRootEntryConfigurator;
              :Configures\ntest sources; <<continuous>>
            fork again
              :[Other ContentRootEntryConfigurator];
            end fork
          }
        fork again
          :[Other ModuleImportConfigurator];
        end fork
      }
    }
  fork again
    :ModulesDependenciesConfigurator;
  fork again
    :ModulesMappingConfigurator;
  fork again
    :GroupModuleConfigurator;
  fork again
    :VersionControlSystemConfigurator;
  fork again
    :SearchScopeConfigurator;
  fork again
    :YFacetConfigurator;
  fork again
    :ProjectPostImportBulkConfigurator <<postImport>>;
    :Delayed: triggers after\nmutable storage committed; <<continuous>>
  end fork
}

partition "**Save Workspace (5%)**" #E8F8F5 {
  :context.workspace.update();

  partition "**Cleanup Phase**" #D5F4E6 {
    :Get ProjectStorageCleanupConfigurator Extension List;
    fork
      :CleanupFacetsStorageConfigurator <<storageLevel>>;
    fork again
      :CleanupModulesStorageConfigurator <<storageLevel>>;
    fork again
      :CleanupLibrariesStorageConfigurator <<storageLevel>>;
    end fork
  }

  partition "**Save Phase**" #D5F4E6 {
    :Get ProjectStorageSaveConfigurator Extension List;
    fork
      :SaveModulesStorageConfigurator <<storageLevel>>;
    fork again
      :SaveLibrariesStorageConfigurator <<storageLevel>>;
    end fork
  }

  :Lock mutableStorage;
  :Set ImportState = IMPORTED;
}

partition "**Post-Import**" #FEF9E7 {
  :ProjectPostImportBulkConfigurator\nlistens to workspace events;

  partition "**Legacy Configurators (EDT)**" #FDF3CF {
    :Get ProjectPostImportLegacyConfigurator Extension List;
    :Handles facets and\nlegacy workspace model; <<continuous>>
    fork
    fork again
        if (Plugin: Java EE) then (<color:green>installed)
            :WebFacetConfigurator;
            :Configures Web Facets\nfor web sub-modules; <<continuous>>
        else (<color:red>not)
            :skip; <<continuous>>
        endif
    fork again
        if (Plugin: Kotlin) then (<color:green>installed)
            :KotlinFacetConfigurator;
            :Configures Web Facets\nfor web sub-modules; <<continuous>>
        else (<color:red>not)
            :skip; <<continuous>>
        endif
    fork again
        :JavadocsProjectImportConfigurator;
        :Test; <<continuous>>
    fork again
        :CCv2YFacetConfigurator;
        :Test; <<continuous>>
    fork again
        :AngularYFacetConfigurator;
        :Test; <<continuous>>
    fork again
        :SpringFacetConfigurator;
        :Test; <<continuous>>
    fork again
        :YFacetConfigurator;
        :Test; <<continuous>>
    fork end
  }

  partition "**Workspace Configurators (Async)**" #FDF3CF {
    :Get ProjectPostImportConfigurator Extension List;
    :every configurator executed in own independent forked coroutine; <<continuous>>
    fork
      :ExtensionDescriptorsConfigurator;
      :Saves extension\ndescriptor mappings; <<continuous>>
    fork again
      :MavenConfigurator;
      :- depends on Maven plugin -\nImports selected Maven modules; <<continuous>>
    fork again
      :AngularConfigurator;
      :- depends on Angular & AngularJS plugins -\nImports selected Angular modules; <<continuous>>
    fork again
        :GradleConfigurator;
        :- depends on Gradle plugin -\nImports selected Gradle modules; <<continuous>>
    fork again
        :EclipseModuleConfigurator;
        :- depends on Eclipse plugin -\nImports selected Eclipse modules; <<continuous>>
    fork again
        :JRebelConfigurator;
        :- depends on JRebel plugin -\nConfigures JRebel facets; <<continuous>>
    fork again
        :KotlinPostImportConfigurator;
        :- if kotlinnature extension registered -\nConfigures Kotlin; <<continuous>>
    fork again
        :JavaLibrarySourcesConfigurator;
        :Downloads and attaches sources\nfor every .jar library; <<continuous>>
    fork again
        :DecompileOotbBinariesConfigurator;
        :Decompiles Platform binaries\nand place under `docs`; <<continuous>>
    fork again
        :DataSourceConfigurator;
        :- Ultimate only -\nConfigures DB schema; <<continuous>>
    fork again
        :XsdSchemaConfigurator;
        :Configures\nJava EE XSD for Cockpit NG; <<continuous>>
    fork again
        :SearchScopeConfigurator;
        :Configures\nProject Search Scopes; <<continuous>>
    fork again
        :TSProjectImportConfigurator;
        :- Init -\nType System\nMeta Model; <<continuous>>
    fork again
        :BSProjectImportConfigurator;
        :- Init -\nBean System\nMeta Model; <<continuous>>
    fork again
        :CngProjectImportConfigurator;
        :- Init -\nCockpit NG\nMeta Model; <<continuous>>
    fork again
        :BackupProjectSettingsConfigurator;
        :- Import Only -\nRestores selected previously entries; <<continuous>>
    end fork
  }

  partition "**Index-Aware Configurators**" #FDF3CF {
    :Get ProjectImportWhenSmartConfigurator Extension List;
    :Runs after\nindexing completes; <<continuous>>
    fork
    fork again
        :LocalServerRunConfigurationWhenSmartConfigurator;
        :Configures Local SAP CX Run Configuration; <<continuous>>
    fork again
        :RemoteDebugRunConfigurationWhenSmartConfigurator;
        :Configures Remote Debug Run Configuration; <<continuous>>
    fork again
        :KotlinWhenSmartConfigurator;
        :Configures Kotlin Compiler & Library; <<continuous>>
    fork again
        :JavaCompilerConfigurator;
        :Configures Java Compiler; <<continuous>>
    fork again
        :AntWhenSmartConfigurator;
        :Configures Ant Installation & targets; <<continuous>>
    fork again
        :VersionControlSystemConfigurator;
        :Configures Version Control Systems; <<continuous>>
    end fork
  }

  :Notify Import Finished;
}

stop
@enduml